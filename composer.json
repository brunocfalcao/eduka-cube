{
    "name": "brunocfalcao/eduka-cube",
    "description": "Eduka - Learning Management Platform",
    "keywords": [
        "brunocfalcao",
        "eduka"
    ],
    "homepage": "https://github.com/brunocfalcao/eduka-cube",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Bruno Falcão",
            "email": "bruno.c.falcao@brunofalcao.me",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^7.4|^8.0",
        "guzzlehttp/guzzle": "^7.2",
        "wildbit/swiftmailer-postmark": "^3.3",
        "predis/predis": "^1.1",
        "spatie/laravel-medialibrary": "^9.4"
    },
    "autoload": {
        "psr-4": {
            "Eduka\\Cube\\": "src/",
            "Eduka\\Database\\Factories\\": "database/factories/",
            "Eduka\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Eduka\\Cube\\EdukaCubeServiceProvider"
            ]
        }
    }
}
